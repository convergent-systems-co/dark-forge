{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GovernanceCompliance",
  "description": "Schema for governance step compliance evidence. Tracks which governance steps were executed for a given PR or issue, and identifies any skipped or incomplete steps.",
  "type": "object",
  "required": [
    "pr_number",
    "issue_number",
    "timestamp",
    "steps"
  ],
  "properties": {
    "pr_number": {
      "type": "integer",
      "description": "The pull request number being evaluated."
    },
    "issue_number": {
      "type": "integer",
      "description": "The GitHub issue number this PR addresses."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the compliance evaluation was performed."
    },
    "repository": {
      "type": "string",
      "description": "Repository in owner/repo format."
    },
    "branch": {
      "type": "string",
      "description": "Branch name for the PR."
    },
    "policy_profile": {
      "type": "string",
      "description": "The policy profile applied to this evaluation."
    },
    "steps": {
      "type": "object",
      "description": "Evidence for each governance step.",
      "required": [
        "plan_created",
        "panel_evaluation",
        "copilot_review",
        "documentation_updated",
        "issue_tracking"
      ],
      "properties": {
        "plan_created": {
          "type": "object",
          "description": "Evidence that an implementation plan was created before coding.",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped", "not_applicable"],
              "description": "Whether the step was completed."
            },
            "plan_path": {
              "type": "string",
              "description": "Path to the plan file in .governance/plans/ directory."
            },
            "evidence": {
              "type": "string",
              "description": "How compliance was verified."
            }
          }
        },
        "panel_evaluation": {
          "type": "object",
          "description": "Evidence that required governance panels were executed.",
          "required": ["status", "required_panels", "present_panels"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped", "not_applicable"]
            },
            "required_panels": {
              "type": "array",
              "items": { "type": "string" },
              "description": "List of panels required by the policy profile."
            },
            "present_panels": {
              "type": "array",
              "items": { "type": "string" },
              "description": "List of panels that actually produced emissions."
            },
            "missing_panels": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Required panels that did not produce emissions."
            },
            "evidence": {
              "type": "string"
            }
          }
        },
        "copilot_review": {
          "type": "object",
          "description": "Evidence that Copilot recommendations were fetched and addressed.",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped", "not_applicable"]
            },
            "polling_attempts": {
              "type": "integer",
              "description": "Number of Copilot polling attempts performed."
            },
            "recommendations_found": {
              "type": "integer",
              "description": "Total Copilot recommendations found."
            },
            "recommendations_addressed": {
              "type": "integer",
              "description": "Recommendations implemented or dismissed with rationale."
            },
            "recommendations_unaddressed": {
              "type": "integer",
              "description": "Recommendations not yet addressed."
            },
            "evidence": {
              "type": "string"
            }
          }
        },
        "documentation_updated": {
          "type": "object",
          "description": "Evidence that affected documentation was updated with the change.",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped", "not_applicable"]
            },
            "files_checked": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Documentation files evaluated for update necessity."
            },
            "files_updated": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Documentation files that were updated."
            },
            "evidence": {
              "type": "string"
            }
          }
        },
        "issue_tracking": {
          "type": "object",
          "description": "Evidence that work is tracked via a GitHub issue.",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped", "not_applicable"]
            },
            "issue_referenced": {
              "type": "boolean",
              "description": "Whether the PR body references an issue."
            },
            "issue_commented": {
              "type": "boolean",
              "description": "Whether the issue was updated with PR status."
            },
            "evidence": {
              "type": "string"
            }
          }
        },
        "review_thread_resolution": {
          "type": "object",
          "description": "Evidence that all review threads were resolved before merge.",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped", "not_applicable"]
            },
            "total_threads": {
              "type": "integer"
            },
            "resolved_threads": {
              "type": "integer"
            },
            "unresolved_threads": {
              "type": "integer"
            },
            "evidence": {
              "type": "string"
            }
          }
        },
        "ci_checks": {
          "type": "object",
          "description": "Evidence that CI checks passed.",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped", "not_applicable"]
            },
            "checks_total": {
              "type": "integer"
            },
            "checks_passed": {
              "type": "integer"
            },
            "evidence": {
              "type": "string"
            }
          }
        }
      }
    },
    "overall_compliance": {
      "type": "string",
      "enum": ["compliant", "non_compliant", "partially_compliant"],
      "description": "Overall compliance determination."
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "severity", "description"],
        "properties": {
          "step": {
            "type": "string",
            "description": "The governance step that was violated."
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"],
            "description": "Severity of the violation."
          },
          "description": {
            "type": "string",
            "description": "What was expected vs. what was found."
          },
          "remediation": {
            "type": "string",
            "description": "How to fix the violation."
          }
        }
      },
      "description": "List of governance step violations found."
    }
  }
}
